# ─────────────────────────────────────────────────
#  MossadGlory ext Krogan — configuration exemple
# ─────────────────────────────────────────────────

# Token du bot Discord
DISCORD_TOKEN=your_bot_token_here

# ID du serveur Discord (guild)
GUILD_ID=123456789012345678

# ─── Salons (IDs Discord) ────────────────────────
# Salon avec l'embed live de la watchlist
CHANNEL_LIVE=123456789012345678
# Salon où les logs sont envoyés
CHANNEL_LOGS=123456789012345678
# Salon où les alertes sont envoyées
CHANNEL_ALERTS=123456789012345678

# ─── Rôles (IDs Discord) ─────────────────────────
# Rôle pingé pour les alertes action (2+ actions)
ROLE_ALERT_ACTION=123456789012345678
# Rôle pingé pour les alertes infiltration (3+ actions)
ROLE_ALERT_INFILTRATION=123456789012345678
# Rôle pingé pour les alertes missile (5+ actions)
ROLE_ALERT_MISSILE=123456789012345678
# Rôle(s) pouvant gérer le bot (séparés par virgule)
ADMIN_ROLES=123456789012345678,987654321098765432

# ─── Seuils d'alertes ────────────────────────────
THRESHOLD_ACTION=2
THRESHOLD_INFILTRATION=3
THRESHOLD_MISSILE=5

# ─── Cooldown alertes (secondes) ─────────────────
ALERT_COOLDOWN=300

# ─── NationsGlory ────────────────────────────────
# Serveur à surveiller
NG_SERVER=lime
# Intervalle de scan en secondes
SCAN_INTERVAL=30
